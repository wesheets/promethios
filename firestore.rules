rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read/write access to waitlist collection for signups
    match /waitlist/{document} {
      allow read, write: if true;
    }
    
    // Require authentication for all other collections
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}

